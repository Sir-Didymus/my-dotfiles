" Vim configuration file

" --- Tabs and indentation ---

set expandtab
set autoindent
set smartindent
set nowrap

" --- Search ---

set incsearch
set ignorecase
set smartcase
set hlsearch

" --- Appearance ---

set number
set relativenumber
set termguicolors

" Keeps cursor centered vertically when scrolling.
set scrolloff=10

set signcolumn=yes

" --- Behavior ---

set clipboard=unnamedplus
